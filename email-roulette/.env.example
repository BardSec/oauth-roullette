# Azure AD app registration — https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
CLIENT_ID=your-application-client-id
CLIENT_SECRET=your-client-secret-value
TENANT_ID=your-tenant-id-or-common

# Must match a Redirect URI registered in your Azure app
REDIRECT_URI=http://localhost:3000/auth/callback

# Optional — change in production; used to sign session cookies
SESSION_SECRET=change-me-in-production

# Optional — port the app listens on (default: 3000)
# PORT=3000
